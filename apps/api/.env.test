# Dedicated API smoke-test database. No tenants are seeded.
NODE_ENV=test
PORT=5001
DATABASE_URL="postgresql://nask@localhost:5432/fleet_fuel_platform_test?schema=public"
REDIS_URL=redis://localhost:6379
JWT_SECRET=test-secret-with-minimum-length
JWT_EXPIRES_IN=15m
PLATFORM_BASE_DOMAIN=platform.test
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PLATFORM_OWNER_EMAIL=test-owner@example.com
PLATFORM_OWNER_PASSWORD=TestPlatform123!
