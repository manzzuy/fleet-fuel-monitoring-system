# API
NODE_ENV=production
PORT=5001
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=public
REDIS_URL=redis://<host>:6379
JWT_SECRET=<strong-secret>
JWT_EXPIRES_IN=15m
PLATFORM_BASE_DOMAIN=platform-stg.example.com
ALLOWED_ORIGINS=https://platform-stg.example.com,https://maqshan.platform-stg.example.com
APP_VERSION=staging
APP_BUILD_SHA=<git-sha>

# Notifications (safe defaults)
NOTIFICATION_PROVIDER=stub
NOTIFICATION_DELIVERY_ENABLED=false
NOTIFICATION_ALLOW_REAL_SENDS_OUTSIDE_PRODUCTION=false
META_WHATSAPP_API_BASE_URL=https://graph.facebook.com
META_WHATSAPP_API_VERSION=v21.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=

# Admin web
NEXT_PUBLIC_API_BASE_URL=https://api-stg.example.com
NEXT_PUBLIC_PLATFORM_BASE_DOMAIN=platform-stg.example.com

# Driver PWA
NEXT_PUBLIC_API_BASE_URL=https://api-stg.example.com
NEXT_PUBLIC_PLATFORM_BASE_DOMAIN=platform-stg.example.com
